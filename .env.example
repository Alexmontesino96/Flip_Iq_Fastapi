# App
ENVIRONMENT=development
DEBUG=true

# CORS (separar con comas)
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Database
DATABASE_URL=postgresql+asyncpg://flipiq:flipiq@localhost:5432/flipiq

# Redis — soft gate (3 free analyses → email → 100/day) + global rate limit
REDIS_URL=redis://localhost:6379/0

# Supabase Auth — obtener en Dashboard → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_JWT_SECRET=your-jwt-secret

# Rate limiting
RATE_LIMIT_PER_MINUTE=60

# eBay API (https://developer.ebay.com)
EBAY_APP_ID=
EBAY_CERT_ID=
EBAY_SANDBOX=true

# Amazon SP-API (https://developer-docs.amazon.com/sp-api/)
AMAZON_REFRESH_TOKEN=
AMAZON_LWA_CLIENT_ID=
AMAZON_LWA_CLIENT_SECRET=
AMAZON_MARKETPLACE_ID=ATVPDKIKX0DER

# Apify (https://apify.com)
APIFY_TOKEN=

# Keepa API (https://keepa.com) — datos de Amazon
KEEPA_API_KEY=

# AI (scoring / summaries) — al menos uno para features LLM
GEMINI_API_KEY=
OPENAI_API_KEY=

# Reranker — Cohere Rerank 4 Pro vía OpenRouter (~$0.005/análisis)
OPEN_ROUTER_API_KEY=

# App
ENVIRONMENT=development
DEBUG=true

# CORS (separar con comas)
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Database
DATABASE_URL=postgresql+asyncpg://flipiq:flipiq@localhost:5432/flipiq

# Redis
REDIS_URL=redis://localhost:6379/0

# Auth / JWT — IMPORTANTE: cambiar en produccion
# Generar: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=change-me-to-a-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Rate limiting
RATE_LIMIT_PER_MINUTE=60

# eBay API (https://developer.ebay.com)
EBAY_APP_ID=
EBAY_CERT_ID=
EBAY_SANDBOX=true

# Amazon SP-API (https://developer-docs.amazon.com/sp-api/)
AMAZON_REFRESH_TOKEN=
AMAZON_LWA_CLIENT_ID=
AMAZON_LWA_CLIENT_SECRET=
AMAZON_MARKETPLACE_ID=ATVPDKIKX0DER

# Apify (https://apify.com)
APIFY_TOKEN=

# Keepa API (https://keepa.com) — datos de Amazon
KEEPA_API_KEY=

# AI (scoring / summaries)
OPENAI_API_KEY=

# Environment
ENVIRONMENT=development
